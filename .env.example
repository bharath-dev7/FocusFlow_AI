# AI Study Assistant — Environment Variables Reference
# Copy this file to .env and fill in the real values for local development.
# For production, set these in Render (backend) and Vercel (frontend) dashboards.

# ─── BACKEND (Render) ──────────────────────────────────────────────────────────

# PostgreSQL connection string from Supabase
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://...

# Strong random secret for JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-here

# Disable AI API by default (uses cached interventions instead)
AI_ENABLED=false

# Optional: Enable Gemini/GPT for the chatbot
# AI_API_KEY=your-api-key-here
# AI_MODEL=gemini-pro


# ─── FRONTEND (Vercel) ─────────────────────────────────────────────────────────

# Your Render backend URL (set this in Vercel dashboard under Environment Variables)
# Format: https://your-app-name.onrender.com/api/v1
VITE_API_URL=https://your-render-app.onrender.com/api/v1
